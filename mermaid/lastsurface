#! /bin/zsh
# Usage: lastsurface [-s|--serial] [SERVER_DIR]
#
# Print dates of MERMAIDs' last transmissions as recorded in their *.out files.
#
# Options:
#    -s, --serial   Print the full float serial name instead of kstnm.
#    SERVER_DIR    Server directory to scan (default: $MERMAID/servers/s_mermaid)
#
# Author: Joel D. Simon <jdsimon@bathymetrix.com>
# Last modified: 11-May-2026, Darwin Kernel Version 23.6.0

if [[ "$1" = "-h" || "$1" = "--help" ]]; then
    sed -ne '/^#/!q;s/^#$/# /;/^# /s/^# //p' < "$0" |
        awk -v f="${1#-h}" '!f && /^Usage:/ || u { u=!/^\s*$/; if (!u) exit } u || f'
    exit 1
fi

print_serial=false
if [[ "$1" = "-s" || "$1" = "--serial" ]]; then
    print_serial=true
    shift
fi

osean2kstnm() {
    local osean=$1
    local split_name len_kstnm len_zeropad zeros kstnm

    split_name=("${(@s/-/)osean}")
    len_kstnm=$(echo -n "$split_name[2]$split_name[3]" | wc -m | tr -d ' ')

    if [[ $len_kstnm -gt 5 ]]; then
        echo "Unexpected input: kstnm greater than five characters: $osean" >&2
        return 1
    elif [[ $len_kstnm -eq 5 ]]; then
        kstnm="$split_name[2]$split_name[3]"
    else
        len_zeropad=$(( 5 - len_kstnm ))
        zeros=$(printf '0%.0s' {1..$len_zeropad})
        kstnm="$split_name[2]$zeros$split_name[3]"
    fi

    printf '%s\n' "$kstnm"
}

export TZ="UTC"

current_epoch=$(date -u +%s)
output_fmt="%d-%b-%Y (%a @ %H:%M:%S %Z)"
input_fmt="%Y-%m-%dT%H:%M:%SZ"
computer=$(uname -s)

MERMAID_ROOT="${MERMAID:-$HOME/mermaid}"
SERVER_DIR="${1:-$MERMAID_ROOT/servers/s_mermaid}"

if [[ ! -d "$SERVER_DIR" ]]; then
    echo "Error: server directory not found: $SERVER_DIR" >&2
    exit 1
fi

labels=()
surface_dates=()
day_diffs=()
label_width=0

for out_file in "$SERVER_DIR"/*.out(N) "$SERVER_DIR"/*/*.out(N); do
    base_name=$(basename "$out_file")
    serial_number=${base_name%.out}

    if [[ "$base_name" = "nohup.out" ]]; then
	continue
    fi

    line=$(grep "sending cmd from ${serial_number}.cmd" "$out_file" | tail -1)

    if [[ -z "$line" ]]; then
        echo "Warning: no last-surface line found in $out_file" >&2
        continue
    fi

    cmd_time=$(cut -c4-21 <<< "$line")

    Y=$(cut -c1-4 <<< "$cmd_time")
    m=$(cut -c5-6 <<< "$cmd_time")
    d=$(cut -c7-8 <<< "$cmd_time")
    H=$(cut -c10-11 <<< "$cmd_time")
    M=$(cut -c13-14 <<< "$cmd_time")
    S=$(cut -c17-18 <<< "$cmd_time")

    date_string="$Y-$m-${d}T$H:$M:${S}Z"

    if [[ "$computer" = Darwin ]]; then
        last_surface_epoch=$(date -ujf "$input_fmt" "$date_string" +%s) || continue
        surface_date=$(date -jf "$input_fmt%z" "$date_string+0000" +"$output_fmt") || continue
    elif [[ "$computer" = Linux ]]; then
        last_surface_epoch=$(date -ud "$date_string" +%s) || continue
        surface_date=$(date -d "$date_string" +"$output_fmt") || continue
    else
        echo "Error: $0 only tested on Linux and Mac computers" >&2
        exit 1
    fi

    if [[ "$print_serial" = true ]]; then
        float_name="$serial_number"
    else
        float_name=$(osean2kstnm "$serial_number") || continue
    fi

    day_diff=$(bc <<< "scale=2; ($current_epoch - $last_surface_epoch) / (60*60*24)")
    day_diff=$(printf '%6.1f' "$day_diff")

    labels+=("$float_name")
    surface_dates+=("$surface_date")
    day_diffs+=("$day_diff")

    if (( ${#float_name} > label_width )); then
        label_width=${#float_name}
    fi
done


for i in {1..${#labels}}; do
    if (( ${day_diffs[$i]%.*} < 30 )); then
	marker=""
    else
	marker=" !"
    fi

    printf "%${label_width}s: %s --> %s days ago%s\n" \
	   "$labels[$i]" \
	   "$surface_dates[$i]" \
	   "$day_diffs[$i]" \
	   "$marker"
done
